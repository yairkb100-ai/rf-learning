# ============================================================================
# תבנית משתני סביבה — העתק קובץ זה ל-  .env  ומלא ערכים אמיתיים.
# הקובץ .env עצמו אינו נשמר ב-git (מכיל סודות). קובץ זה כן — כתבנית בלבד.
# ============================================================================

# --- שרת ---
PORT=3000

# מקור מורשה ל-CORS (כתובת האתר). מספר כתובות מופרדות בפסיק.
# בייצור מומלץ מאוד להגדיר. אם ריק — ה-API פתוח לכל מקור.
# CORS_ORIGIN=https://learn.your-org.co.il

# --- בסיס נתונים (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rf_learning
DB_USER=postgres
DB_PASSWORD=

# --- JWT (אימות) ---
# חובה! מחרוזות אקראיות ארוכות. צור למשל ע"י:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# בלי הערכים האלה השרת יסרב לעלות.
JWT_SECRET=
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRES_IN=7d
